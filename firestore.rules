rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test document
    match /test/connection {
      allow read: if true;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn(); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // --- ENTITY VALIDATION HELPERS ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'category', 'image']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.image is string && data.image.size() <= 1000;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId is string &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'shipped', 'delivered', 'received', 'cancelled', 'returning', 'returned'] &&
             data.createdAt == request.time;
    }

    function isValidCart(data) {
      return data.keys().hasAll(['items', 'updatedAt']) &&
             data.items is list &&
             data.updatedAt == request.time;
    }

    // --- MATCH BLOCKS ---

    // USERS: Private profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming()) &&
                    incoming().uid == existing().uid; // Immutable UID
    }

    // PRODUCTS: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }


    // ORDERS: Owner read/create, Admin full access
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isOwner(incoming().userId) && isValidOrder(incoming());
      allow update: if isAdmin() || (
        isOwner(existing().userId) && 
        isValidOrder(incoming()) &&
        incoming().userId == existing().userId && // Immutable owner
        incoming().createdAt == existing().createdAt && // Immutable creation time
        // Only allow status changes for owners in specific conditions (e.g., cancelling)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
          incoming().status == 'cancelled' &&
          existing().status == 'pending'
        )
      );
      allow delete: if isAdmin();
    }

    // CARTS: Private to user
    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidCart(incoming());
    }
    // ADMINS: System collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Cloud Console for max security
    }
  }
}
